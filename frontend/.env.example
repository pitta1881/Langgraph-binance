# API endpoint base. Optional — defaults to "/api" which works for both:
#   • dev: Vite proxy forwards /api/* to the gateway on :8000
#   • prod single-image: gateway serves the SPA + API on the same origin
# Only set this if you're running the frontend AGAINST a gateway hosted on a
# different origin (and remember to include the /api suffix).
VITE_API_URL=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ADMIN_EMAILS=
